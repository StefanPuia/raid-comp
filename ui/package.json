{
	"name": "raid-comp-ui",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "yarn smui-theme-dark",
		"smui-theme-light": "smui-theme compile static/smui-light.css -i src/theme/light",
		"smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark"
	},
	"devDependencies": {
		"@haverstack/axios-fetch-adapter": "0.12.0",
		"@material/typography": "^14.0.0",
		"@smui-extra/bottom-app-bar": "^8.0.3",
		"@smui/button": "^8.0.3",
		"@smui/card": "^8.0.3",
		"@smui/circular-progress": "^8.0.3",
		"@smui/common": "^8.0.3",
		"@smui/dialog": "^8.0.3",
		"@smui/fab": "^8.0.3",
		"@smui/icon-button": "^8.0.3",
		"@smui/layout-grid": "^8.0.3",
		"@smui/list": "8.0.3",
		"@smui/menu": "^8.0.3",
		"@smui/paper": "^8.0.3",
		"@smui/segmented-button": "^8.0.3",
		"@smui/select": "8.0.3",
		"@smui/snackbar": "^8.0.3",
		"@smui/textfield": "^8.0.3",
		"@smui/tooltip": "^8.0.3",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"typescript-eslint": "^8.58.1",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"axios": "1.15.0",
		"axios-mock-adapter": "^2.1.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"smui-theme": "^8.0.3",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-turnstile": "0.11.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.7",
		"wrangler": "4.81.0"
	},
	"type": "module",
	"dependencies": {
		"svelte-i18n": "^4.0.1"
	}
}
