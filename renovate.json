{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
"config:recommended"
  ],
  "ignoreDeps": [
    "i18next",
    "react-i18next"
  ],
  "labels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "managerFilePatterns": [
        "/^gradle/libs.versions.toml$/"
      ],
      "customType": "regex",
      "matchStrings": [
        "googleJavaFormat = \"(?<currentValue>.*?)\""
      ],
      "depNameTemplate": "com.google.googlejavaformat:google-java-format",
      "datasourceTemplate": "maven"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    }
  ]
}
