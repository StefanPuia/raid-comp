{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "security:minimumReleaseAgeNpm"
  ],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "managerFilePatterns": ["/^gradle/libs.versions.toml$/"],
      "customType": "regex",
      "matchStrings": ["googleJavaFormat = \"(?<currentValue>.*?)\""],
      "depNameTemplate": "com.google.googlejavaformat:google-java-format",
      "datasourceTemplate": "maven"
    }
  ]
}
